# Weights & Biases
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=contract-intelligence
WANDB_ENTITY=your_wandb_username_here

# Hugging Face (optional, for private models)
HF_TOKEN=your_hf_token_here

# Model config
BASE_MODEL=nlpaueb/legal-bert-base-uncased
MAX_SEQ_LENGTH=512
BATCH_SIZE=16
LEARNING_RATE=2e-5
NUM_EPOCHS=5

# Paths
DATA_DIR=./data
MODEL_DIR=./models
LOG_DIR=./logs
